{
  "name": "book-review-app",
  "version": "1.0.0",
  "description": "Book Review website for course project",
  "main": "server.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=routes.test.js",
    "test:integration": "jest --testPathPatterns=routes.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  },
  "build": {
    "appId": "com.hutaboo.bookreview",
    "productName": "HuTaBoo",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HuTaBoo"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!CVS/**/*",
      "!.git/**/*",
      "!.github/**/*",
      "!.gitignore",
      "!.agents/**/*",
      "!baocao1.md",
      "!AC3030_dan_y_bao_cao_BTL.md",
      "!BTL Module 2 - hutaboo.docx",
      "!Huong_dan_thuc_hanh_Playwright_Integration_Test.docx",
      "!Tuần.docx",
      "!architecture_flow.txt",
      "!baocao.txt",
      "!design-patterns-en.pdf",
      "!jest.config.js",
      "!test-sqlite3.js",
      "!test-query-parser.js",
      "!**/*.test.js",
      "!tests/**/*",
      "!scratch/**/*"
    ],
    "asar": true
  }
}
